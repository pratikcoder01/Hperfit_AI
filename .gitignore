# ─────────────────────────────────────────────
#  HyperFitness — .gitignore
# ─────────────────────────────────────────────

# ── Node / Next.js ────────────────────────────
node_modules/
.next/
out/
dist/
build/
*.tsbuildinfo
.turbo/

# ── Environment ───────────────────────────────
.env
.env.local
.env.production
.env.staging
!.env.example

# ── Python / FastAPI ──────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
venv/
.venv/
env/
ENV/

# ── Alembic ───────────────────────────────────
# (keep migrations folder but ignore __pycache__)
backend/alembic/__pycache__/

# ── VS Code ───────────────────────────────────
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json

# ── OS ────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Logs ─────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ── Testing ───────────────────────────────────
coverage/
.nyc_output/

# ── Misc ─────────────────────────────────────
*.bak
*.swp
*.orig
