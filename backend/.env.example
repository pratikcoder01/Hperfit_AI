# ─────────────────────────────────────────────
#  HyperFitness — Backend Environment Variables
# ─────────────────────────────────────────────

# Application
APP_NAME=HyperFitness
APP_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=True

# API
API_PREFIX=/api/v1

# Database — Replace with your Supabase PostgreSQL URL
DATABASE_URL=postgresql+asyncpg://postgres:your-password@db.your-project.supabase.co:5432/postgres

# JWT — CHANGE THIS IN PRODUCTION!
SECRET_KEY=your-super-secret-jwt-key-minimum-32-characters-long
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_DAYS=30

# Security
BCRYPT_ROUNDS=12
RATE_LIMIT_PER_MINUTE=100

# CORS — Add your Vercel domain
ALLOWED_ORIGINS=["http://localhost:3000","https://your-app.vercel.app"]
